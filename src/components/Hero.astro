---

---

<section
    class="hero-wrapper"
    style="height: 200vh; position: relative; background: var(--lino);"
>
    <div
        class="hero-sticky"
        style="
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  "
    >
        <div
            class="curtain-left"
            style="
      position: absolute;
      inset: 0;
      width: 50%;
      background: var(--lino);
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 0.5rem;
      z-index: 10;
    "
        >
            <span
                data-i18n="hero.curtain.left"
                style="
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.5rem, 5vw, 3.5rem);
        color: var(--text-dark);
        white-space: nowrap;
        text-align: right;
        display: block;
      "
                >Las personas te dicen</span
            >
        </div>

        <div
            class="curtain-right"
            style="
      position: absolute;
      top: 0; right: 0; bottom: 0;
      width: 50%;
      background: var(--lino);
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding-left: 0.5rem;
      z-index: 10;
    "
        >
            <span
                data-i18n="hero.curtain.right"
                style="
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.5rem, 5vw, 3.5rem);
        color: var(--text-dark);
        white-space: nowrap;
        text-align: left;
        display: block;
      "
                >lo que piensan</span
            >
        </div>

        <div
            class="mobile-phrase-1"
            style="
      position: absolute;
      width: 100%;
      text-align: center;
      padding: 0 2rem;
      z-index: 10;
    "
        >
            <p
                data-i18n="hero.curtain.full"
                style="
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.4rem, 6vw, 2rem);
        color: var(--text-dark);
        line-height: 1.3;
      "
            >
                Las personas te dicen lo que piensan
            </p>
        </div>

        <div
            class="hero-revealed"
            style="
      position: absolute;
      opacity: 0;
      text-align: center;
      padding: 0 2rem;
      z-index: 5;
      width: 100%;
    "
        >
            <p
                data-i18n="hero.revealed"
                style="
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.5rem, 5vw, 3.5rem);
        color: var(--violeta);
        line-height: 1.2;
        text-align: center;
      "
            >
                Yo descubro por qué lo piensan
            </p>
        </div>

        <div
            class="hero-identity"
            style="
      position: absolute;
      bottom: 10vh;
      left: 0; right: 0;
      opacity: 0;
      transform: translateY(20px);
      text-align: center;
      z-index: 5;
      padding: 0 2rem;
    "
        >
            <div
                style="width: 52px; height: 1px; background: var(--terracota); margin: 0 auto 1.75rem;"
            >
            </div>
            <h1
                data-i18n="hero.name"
                style="
        font-family: 'DM Serif Display', serif;
        font-size: clamp(2rem, 5vw, 52px);
        color: var(--text-dark);
        line-height: 1.05;
      "
            >
                Linamaría Martínez
            </h1>
            <p
                data-i18n="hero.role"
                style="
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: var(--musgo);
        margin-top: 0.8rem;
        letter-spacing: 0.04em;
      "
            >
                Investigadora UX · IA con criterio humano
            </p>
            <div
                class="scroll-arrow"
                style="margin-top: 2.5rem; color: var(--terracota); font-size: 1.2rem;"
            >
                ↓
            </div>
        </div>
    </div>
</section>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const MOBILE = window.innerWidth <= 480;

    if (MOBILE) {
        // Ocultar cortinas, mostrar frase mobile
        const cl = document.querySelector(".curtain-left") as HTMLElement;
        const cr = document.querySelector(".curtain-right") as HTMLElement;
        if (cl) cl.style.display = "none";
        if (cr) cr.style.display = "none";

        const phrase1 = document.querySelector(
            ".mobile-phrase-1",
        ) as HTMLElement;
        const revealed = document.querySelector(
            ".hero-revealed",
        ) as HTMLElement;
        const identity = document.querySelector(
            ".hero-identity",
        ) as HTMLElement;
        const wrapper = document.querySelector(".hero-wrapper") as HTMLElement;

        if (revealed) {
            revealed.style.zIndex = "15";
            revealed.style.opacity = "0";
        }
        if (identity) {
            identity.style.zIndex = "15";
            identity.style.opacity = "0";
        }

        function onHeroScroll() {
            const scrollRange = wrapper.offsetHeight - window.innerHeight;
            const scrolled = Math.max(0, -wrapper.getBoundingClientRect().top);
            const p = Math.min(scrolled / scrollRange, 1);

            if (phrase1)
                phrase1.style.opacity = String(Math.max(0, 1 - p / 0.35));
            if (revealed)
                revealed.style.opacity = String(
                    Math.min(Math.max(0, (p - 0.35) / 0.3), 1),
                );
            const idP = Math.min(Math.max(0, (p - 0.65) / 0.2), 1);
            if (identity) {
                identity.style.opacity = String(idP);
                identity.style.transform = `translateY(${(1 - idP) * 20}px)`;
            }
        }

        window.addEventListener("scroll", onHeroScroll, { passive: true });
        onHeroScroll();
    } else {
        // Desktop y tablet — cortinas + ScrollTrigger
        function centerCurtains() {
            const leftSpan = document.querySelector(
                ".curtain-left span",
            ) as HTMLElement;
            const rightSpan = document.querySelector(
                ".curtain-right span",
            ) as HTMLElement;
            const curtainLeft = document.querySelector(
                ".curtain-left",
            ) as HTMLElement;
            const curtainRight = document.querySelector(
                ".curtain-right",
            ) as HTMLElement;
            if (!leftSpan || !rightSpan) return;
            const leftWidth = leftSpan.getBoundingClientRect().width;
            const rightWidth = rightSpan.getBoundingClientRect().width;
            const totalWidth = leftWidth + rightWidth;
            const viewportWidth = window.innerWidth;
            const splitPoint = (viewportWidth - totalWidth) / 2 + leftWidth;
            const splitPercent = (splitPoint / viewportWidth) * 100;
            curtainLeft.style.width = splitPercent + "%";
            curtainRight.style.width = 100 - splitPercent + "%";
            curtainRight.style.left = splitPercent + "%";
            curtainRight.style.right = "auto";
        }

        centerCurtains();
        window.addEventListener("resize", centerCurtains);

        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: ".hero-wrapper",
                start: "top top",
                end: "bottom bottom",
                scrub: 1,
            },
        });

        tl.to(".curtain-left", { x: "-100%", ease: "none", duration: 1 }, 0)
            .to(".curtain-right", { x: "100%", ease: "none", duration: 1 }, 0)
            .to(
                ".hero-revealed",
                { opacity: 1, ease: "none", duration: 0.5 },
                0.35,
            )
            .to(
                ".hero-identity",
                { opacity: 1, y: 0, ease: "none", duration: 0.4 },
                0.65,
            );
    }
</script>

<style>
    .mobile-phrase-1 {
        display: none;
    }

    @media (max-width: 480px) {
        .curtain-left,
        .curtain-right {
            display: none;
        }
        .mobile-phrase-1 {
            display: block;
        }
    }

    @media (min-width: 481px) and (max-width: 1024px) {
        .curtain-left span,
        .curtain-right span {
            font-size: clamp(1.75rem, 4vw, 2.75rem) !important;
        }
    }
</style>
